<?xml version="1.0"?>
<!-- Revolute-Revolute Manipulator -->
<robot name="hexa_x_tilt" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Constants for robot dimensions -->
  <xacro:property name="PI" value="3.1415926535897931"/>
  

  <link name='base_link'>
    <origin xyz="0 0 0" rpy="1.57 0 3.14"/>
    <inertial>
      <pose>0.0 0 0 0 0 0</pose>
      <mass value="5.0"/>
      <inertia  ixx="0.3" iyy="0.3" izz="0.3" ixy="0" ixz="0" iyz="0" />
    </inertial>
    <collision name='base_link_collision'>
      <origin xyz="0 0 0" rpy="1.57 0 3.14"/>
      <geometry>
          <!-- <mesh filename = "model://hexa_x_tilt/meshes/main_body.stl" scale="0.001 0.001 0.001"/> -->
        <box size="0.8 0.4 0.8"/>
      </geometry>
    </collision>
    <visual name='base_link_visual'>
      <origin xyz="0 0 0" rpy="1.57 0 3.14"/>
      <geometry>
          <mesh filename = "model://hexa_x_tilt/meshes/main_body.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <gravity>1</gravity>
    <self_collide>0</self_collide>
  </link>


  <link name='manipulator_base_yaw'>
    <origin xyz="0 0 0" rpy="1.57 0 0"/>
    <inertial>
      <pose>0 0 0 0 0 0</pose>
      <mass value="0.3"/>
      <inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0" ixz="0" iyz="0" />
    </inertial>
    <collision name='manipulator_base_yaw_collision'>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry>
          <mesh filename = "model://hexa_x_tilt/meshes/arm_base_yaw.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    <visual name='manipulator_base_yaw_visual'>
      <origin xyz="0 0 0" rpy="1.57 0 0"/>
      <geometry>
          <mesh filename = "model://hexa_x_tilt/meshes/arm_base_yaw.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <self_collide>0</self_collide>
  </link>

  <joint name='manipulator_base_yaw_joint' type='revolute'>
      <origin xyz="0.06 0 0.065" rpy="0 0 0"/>
      <parent link='base_link'/>
      <child link='manipulator_base_yaw'/>
      <limit lower="-3.1" upper="3.1" effort="10" velocity="1"/>
      <axis xyz="0 0 1"/>    
  </joint>

  <link name='manipulator_arm1'>
      <origin xyz="0 0 0" rpy="1.57 -1.57 0"/>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass value="0.3"/>
        <inertia ixx="0.007" iyy="0.007" izz="0.0005" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <collision name='manipulator_arm1_collision'>
        <origin xyz="0 0 0" rpy="1.57 -1.57 0"/>
        <geometry>
          <mesh filename = "model://hexa_x_tilt/meshes/arm_link1_pitch.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </collision>
      <visual name='manipulator_arm1_visual'>
        <origin xyz="0 0 0" rpy="1.57 -1.57 0"/>
        <geometry>
          <mesh filename = "model://hexa_x_tilt/meshes/arm_link1_pitch.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </visual>
      <self_collide>0</self_collide>
  </link>

  <joint name='manipulator_arm1_joint' type='revolute'>
    <origin xyz="0 0 0.0485" rpy="0 0 0"/>
    <parent link='manipulator_base_yaw'/>
    <child link='manipulator_arm1'/>
    <limit lower="-3.1" upper="3.1" effort="10" velocity="1"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name='manipulator_arm2'>
      <origin xyz="0 0 0" rpy="1.57 -1.57 0"/>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass value="0.3"/>
        <inertia ixx="0.007" iyy="0.007" izz="0.0005" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <collision name='manipulator_arm2_collision'>
        <origin xyz="0 0 0" rpy="1.57 -1.57 0"/>
        <geometry>
          <mesh filename = "model://hexa_x_tilt/meshes/arm_link2_pitch.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </collision>
      <visual name='manipulator_arm2_visual'>
        <origin xyz="0 0 0" rpy="1.57 -1.57 0"/>
        <geometry>
          <mesh filename = "model://hexa_x_tilt/meshes/arm_link2_pitch.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </visual>
      <self_collide>0</self_collide>
  </link>
    
  <joint name='manipulator_arm2_joint' type='revolute'>
      <origin xyz="0 0 0.4435" rpy="0 0 0"/>
      <parent link='manipulator_arm1'/>
      <child link='manipulator_arm2'/>
      <limit lower="-3.1" upper="3.1" effort="10" velocity="1"/>
      <axis xyz="0 1 0"/>
  </joint>

  <link name='manipulator_finger1'>
    <origin xyz="0 0 0" rpy="1.57 0 -1.57"/>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass value="0.05"/>
        <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <collision name='manipulator_finger1_collision'>
        <origin xyz="0 0 0" rpy="1.57 0 -1.57"/>
        <geometry>
          <mesh filename = "model://hexa_x_tilt/meshes/finger.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </collision>
      <visual name='manipulator_finger1_visual'>
        <origin xyz="0 0 0" rpy="1.57 0 -1.57"/>
        <geometry>
          <mesh filename = "model://hexa_x_tilt/meshes/finger.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </visual>
      <self_collide>0</self_collide>
  </link>

  <joint name='manipulator_finger1_joint' type = 'fixed'>
    <origin xyz="0 0 0.446" rpy="0 0 0"/>
      <parent link='manipulator_arm2'/>
      <child link='manipulator_finger1'/>
      <limit lower="0.0" upper="0.04" effort="10" velocity="0.2" />
      <axis xyz="0 1 0"/>
  </joint>

  <link name='manipulator_finger2'>
    <origin xyz="0 0 0" rpy="1.57 0 1.57"/>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass value="0.05"/>
        <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0" />
      </inertial>
      <collision name='manipulator_finger2_collision'>
        <origin xyz="0 0 0" rpy="1.57 0 1.57"/>
        <geometry>
          <mesh filename = "model://hexa_x_tilt/meshes/finger.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </collision>
      <visual name='manipulator_finger2_visual'>
        <origin xyz="0 0 0" rpy="1.57 0 1.57"/>
        <geometry>
          <mesh filename = "model://hexa_x_tilt/meshes/finger.stl" scale="0.001 0.001 0.001" />
        </geometry>
      </visual>
      <self_collide>0</self_collide>
  </link>
  <joint name='manipulator_finger2_joint' type = 'fixed'>
    <origin xyz="0 0 0.446" rpy="0 0 0"/>
      <parent link='manipulator_arm2'/>
      <child link='manipulator_finger2'/>
      <axis xyz="0 1 0"/>
      <limit lower="-0.04" upper="0.0" effort="10" velocity="0.2" />
  </joint>



  <link name='hexa_x_tilt/imu_link'>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.015"/>
      <inertia ixx="1e-05" ixy="0" ixz="0" iyy="1e-05" iyz="0" izz="1e-05"/>
    </inertial>
  </link>
  <joint name='hexa_x_tilt/imu_joint' type='fixed'>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link='base_link'/>
      <child link='hexa_x_tilt/imu_link'/>
      <axis xyz="1 0 0"/>
      <limit effort="0" velocity="0" lower="0" upper="0"/>
  </joint>      
  <link name='rotor_3'>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.005"/>
        <inertia ixx="9.75e-07" ixy="0" ixz="0" iyy="0.000273104" iyz="0" izz="0.000274004"/>
      </inertial>
      <visual name='rotor_3_visual'>
        <origin xyz="-0.211396 0.119762 0.082219" rpy="0 0 0"/>
        <geometry>
          <mesh filename="model://hexa_x_tilt/meshes/prop_ccw_assembly_remeshed_v3.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>
      <gravity>1</gravity>
      <velocity_decay/>
      <self_collide>0</self_collide>
  </link>
  <joint name='rotor_3_joint' type='revolute'>
      <origin xyz="0.209396 0.122762 0.082219" rpy="0 -0.523598 -1.04719"/>
      <parent link='base_link'/>
      <child link='rotor_3'/>
      <axis xyz="-0.251 0.428 0.866025"/>
      <limit lower="-1e+16" upper="1e+16" effort="10" velocity="-1"/>
  </joint>
  <link name='rotor_0'>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertial>  
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.005"/>
        <inertia ixx="9.75e-07" ixy="0" ixz="0" iyy="0.000273104" iyz="0" izz="0.000274004"/>
      </inertial>
      <visual name='rotor_0_visual'>
        <origin xyz="-0.211396 0.119762 0.082219" rpy="0 0 0"/>
        <geometry>
          <mesh filename="model://hexa_x_tilt/meshes/prop_cw_assembly_remeshed_v3.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>
      <gravity>1</gravity>
      <velocity_decay/>
      <self_collide>0</self_collide>
  </link>
  <joint name='rotor_0_joint' type='revolute'>
      <origin xyz="-0.209396 0.122762 0.082219" rpy="0 -0.523598 1.04719"/>
      <parent link='base_link'/>
      <child link='rotor_0'/>
      <axis xyz="0.251 0.428 0.866025"/>
      <limit lower="-1e+16" upper="1e+16" effort="10" velocity="-1"/>
  </joint>
    <link name='rotor_4'>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.005"/>
        <inertia ixx="9.75e-07" ixy="0" ixz="0" iyy="0.000273104" iyz="0" izz="0.000274004"/>
      </inertial>
      <visual name='rotor_4_visual'>
        <origin xyz="0.00187896 -0.242705 -0.0822169" rpy="0 0 0"/>
        <geometry>
          <mesh filename="model://hexa_x_tilt/meshes/prop_ccw_assembly_remeshed_v3.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>
      <gravity>1</gravity>
      <velocity_decay/>
      <self_collide>0</self_collide>
    </link>
    <joint name='rotor_4_joint' type='revolute'>
      <origin xyz="0 0.242728 0.0822169" rpy="0 0.523698 0"/>
      <parent link='base_link'/>
      <child link='rotor_4'/>
      <axis xyz="0.5 0 0.866025"/>
      <limit lower="-1e+16" upper="1e+16" effort="10" velocity="-1"/>
    </joint>
    <link name='rotor_1'>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.005"/>
        <inertia ixx="9.75e-07" ixy="0" ixz="0" iyy="0.000273104" iyz="0" izz="0.000274004"/>
      </inertial>
      <visual name='rotor_1_visual'>
        <origin xyz="0..00187896 -0.242705 -0.0822169" rpy="0 0 0"/>
        <geometry>
          <mesh filename="model://hexa_x_tilt/meshes/prop_cw_assembly_remeshed_v3.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>
      <gravity>1</gravity>
      <velocity_decay/>
      <self_collide>0</self_collide>
    </link>
    <joint name='rotor_1_joint' type='revolute'>
      <origin xyz="0.209396 -0.122762 0.082219" rpy="0 0.523598 -2.09439510239"/>
      <parent link='base_link'/>
      <child link='rotor_1'/>
      <axis xyz="-0.251 -0.428 0.866025"/>
      <limit lower="-1e+16" upper="1e+16" effort="10" velocity="-1"/>
    </joint>

    <link name='rotor_5'>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.005"/>
        <inertia ixx="9.75e-07" ixy="0" ixz="0" iyy="0.000273104" iyz="0" izz="0.000274004"/>
      </inertial>
      <visual name='rotor_5_visual'>
        <origin xyz="-0.211396 -0.119762 -0.082219" rpy="0 0 0"/>
        <geometry>
          <mesh filename="model://hexa_x_tilt/meshes/prop_ccw_assembly_remeshed_v3.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>
      <gravity>1</gravity>
      <velocity_decay/>
      <self_collide>0</self_collide>
    </link>
    <joint name='rotor_5_joint' type='revolute'>
      <origin xyz="0 -0.242728 0.0822169" rpy="0 -0.523698 -3.141592653"/>
      <parent link='base_link'/>
      <child link='rotor_5'/>
      <axis xyz="-0.5 0 0.866025"/>
      <limit lower="-1e+16" upper="1e+16" effort="10" velocity="-1"/>
    </joint>
    <link name='rotor_2'>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.005"/>
        <inertia ixx="9.75e-07" ixy="0" ixz="0" iyy="0.000273104" iyz="0" izz="0.000274004"/>
      </inertial>
      <visual name='rotor_2_visual'>
        <origin xyz="0.00187896 -0.242705 -0.0822169" rpy="0 0 0"/>
        <geometry>
          <mesh filename="model://hexa_x_tilt/meshes/prop_cw_assembly_remeshed_v3.stl" scale="0.001 0.001 0.001"/>
        </geometry>
      </visual>
      <gravity>1</gravity>
      <velocity_decay/>
      <self_collide>0</self_collide>
    </link>
    <joint name='rotor_2_joint' type='revolute'>
      <origin xyz="-0.209396 -0.122762 0.082219" rpy="0 0.523598 2.09439510239"/>
      <parent link='base_link'/>
      <child link='rotor_2'/>
      <axis xyz="0.251 -0.428 0.866025"/>
      <limit lower="-1e+16" upper="1e+16" effort="10" velocity="-1"/>
    </joint>

  <gazebo>
    <include>
      <uri>model://gps</uri>
      <pose>0 0 0 0 0 0</pose>
      <name>gps</name>
    </include>
    <joint name='gps_joint' type='fixed'>
      <child>gps::link</child>
      <parent>base_link</parent>
    </joint>
  </gazebo>


  <gazebo>
      <plugin filename="librotors_gazebo_multirotor_base_plugin.so" name="rosbag">
        <robotNamespace></robotNamespace>
        <linkName>base_link</linkName>
        <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      </plugin>
  </gazebo>

  <gazebo>
    <plugin name='front_right_motor_model' filename='libgazebo_motor_model.so'>
      <robotNamespace></robotNamespace>
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1800</maxRotVelocity>
      <motorConstant>5.84e-06</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>5</motorNumber>
      <rotorDragCoefficient>0.000175</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>/motor_speed/5</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
    <plugin name='back_left_motor_model' filename='libgazebo_motor_model.so'>
      <robotNamespace></robotNamespace>
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1800</maxRotVelocity>
      <motorConstant>5.84e-06</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>4</motorNumber>
      <rotorDragCoefficient>0.000175</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>/motor_speed/4</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
    <plugin name='front_left_motor_model' filename='libgazebo_motor_model.so'>
      <robotNamespace></robotNamespace>
      <jointName>rotor_2_joint</jointName>
      <linkName>rotor_2</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1800</maxRotVelocity>
      <motorConstant>5.84e-06</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>3</motorNumber>
      <rotorDragCoefficient>0.000175</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>/motor_speed/3</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
    <plugin name='back_right_motor_model' filename='libgazebo_motor_model.so'>
      <robotNamespace></robotNamespace>
      <jointName>rotor_3_joint</jointName>
      <linkName>rotor_3</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1800</maxRotVelocity>
      <motorConstant>5.84e-06</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>2</motorNumber>
      <rotorDragCoefficient>0.000175</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>/motor_speed/2</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
    <plugin name='back_left_motor_model' filename='libgazebo_motor_model.so'>
      <robotNamespace></robotNamespace>
      <jointName>rotor_4_joint</jointName>
      <linkName>rotor_4</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1800</maxRotVelocity>
      <motorConstant>5.84e-06</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>1</motorNumber>
      <rotorDragCoefficient>0.000175</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>/motor_speed/1</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
    <plugin name='front_left_motor_model' filename='libgazebo_motor_model.so'>
      <robotNamespace></robotNamespace>
      <jointName>rotor_5_joint</jointName>
      <linkName>rotor_5</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1800</maxRotVelocity>
      <motorConstant>5.84e-06</motorConstant>
      <momentConstant>0.06</momentConstant>
      <commandSubTopic>/gazebo/command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>0.000175</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-06</rollingMomentCoefficient>
      <motorSpeedPubTopic>/motor_speed/0</motorSpeedPubTopic>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
    </plugin>
  </gazebo>
  <gazebo>
      <plugin name='magnetometer_plugin' filename='libgazebo_magnetometer_plugin.so'>
      <robotNamespace/>
      <pubRate>100</pubRate>
      <noiseDensity>0.000</noiseDensity>
      <randomWalk>6.4e-06</randomWalk>
      <biasCorrelationTime>600</biasCorrelationTime>
      <magTopic>/mag</magTopic>
    </plugin>
    <plugin name='barometer_plugin' filename='libgazebo_barometer_plugin.so'>
      <robotNamespace/>
      <pubRate>50</pubRate>
      <baroTopic>/baro</baroTopic>
    </plugin>
  </gazebo>
  <gazebo>
    <plugin name='gazebo_imu_plugin' filename='librotors_gazebo_imu_plugin.so'>
      <robotNamespace></robotNamespace>
      <linkName>hexa_x_tilt/imu_link</linkName>
      <imuTopic>/imu</imuTopic>
      <gyroscopeNoiseDensity>0.0003394</gyroscopeNoiseDensity>
      <gyroscopeRandomWalk>3.8785e-05</gyroscopeRandomWalk>
      <gyroscopeBiasCorrelationTime>1000.0</gyroscopeBiasCorrelationTime>
      <gyroscopeTurnOnBiasSigma>0.0087</gyroscopeTurnOnBiasSigma>
      <accelerometerNoiseDensity>0.004</accelerometerNoiseDensity>
      <accelerometerRandomWalk>0.006</accelerometerRandomWalk>
      <accelerometerBiasCorrelationTime>300.0</accelerometerBiasCorrelationTime>
      <accelerometerTurnOnBiasSigma>0.196</accelerometerTurnOnBiasSigma>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name="p3d_base_controller" filename="libgazebo_ros_p3d.so">
      <alwaysOn>true</alwaysOn>
      <updateRate>200.0</updateRate>
      <bodyName>base_link</bodyName> <!-- This is the link for which ground truth data will be published. It is also used as the child_frame_id in the odometry message, which is not the correct thing to do because the linear and angular velocity are actually in the world frame, not the 'bodyName' frame. The core_odometry_transform packge will handle this by publishing a new odometry message with the frame_id and child_frame_id corrected.  -->
      <topicName>ground_truth/state</topicName>
      <gaussianNoise>0.0</gaussianNoise>
      <frameName>world</frameName>
      <xyzOffsets>0 0 0</xyzOffsets>
      <rpyOffsets>0 0 0</rpyOffsets>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin name='mavlink_interface' filename='libgazebo_mavlink_interface.so'>
      <robotNamespace></robotNamespace>
      <imuSubTopic>/imu</imuSubTopic>
      <magSubTopic>/mag</magSubTopic>
      <baroSubTopic>/baro</baroSubTopic>
      <mavlink_addr>INADDR_ANY</mavlink_addr>
      <mavlink_tcp_port>4560</mavlink_tcp_port>
      <mavlink_udp_port>14560</mavlink_udp_port>
      <serialEnabled>0</serialEnabled>
      <serialDevice>/dev/ttyACM0</serialDevice>
      <baudRate>921600</baudRate>
      <qgc_addr>INADDR_ANY</qgc_addr>
      <qgc_udp_port>14550</qgc_udp_port>
      <sdk_addr>INADDR_ANY</sdk_addr>
      <sdk_udp_port>14540</sdk_udp_port>
      <hil_mode>0</hil_mode>
      <hil_state_level>false</hil_state_level>
      <enable_lockstep>true</enable_lockstep>
      <use_tcp>true</use_tcp>
      <motorSpeedCommandPubTopic>/gazebo/command/motor_speed</motorSpeedCommandPubTopic>
      <control_channels>
        <channel name="rotor0">
          <input_index>0</input_index>
          <input_offset>0</input_offset>
          <input_scaling>1500</input_scaling>
          <zero_position_disarmed>0</zero_position_disarmed>
          <zero_position_armed>100</zero_position_armed>
          <joint_control_type>velocity</joint_control_type>
        </channel>
        <channel name="rotor1">
          <input_index>1</input_index>
          <input_offset>0</input_offset>
          <input_scaling>1500</input_scaling>
          <zero_position_disarmed>0</zero_position_disarmed>
          <zero_position_armed>100</zero_position_armed>
          <joint_control_type>velocity</joint_control_type>
        </channel>
        <channel name="rotor2">
          <input_index>2</input_index>
          <input_offset>0</input_offset>
          <input_scaling>1500</input_scaling>
          <zero_position_disarmed>0</zero_position_disarmed>
          <zero_position_armed>100</zero_position_armed>
          <joint_control_type>velocity</joint_control_type>
        </channel>
        <channel name="rotor3">
          <input_index>3</input_index>
          <input_offset>0</input_offset>
          <input_scaling>1500</input_scaling>
          <zero_position_disarmed>0</zero_position_disarmed>
          <zero_position_armed>100</zero_position_armed>
          <joint_control_type>velocity</joint_control_type>
        </channel>
        <channel name="rotor4">
          <input_index>4</input_index>
          <input_offset>0</input_offset>
          <input_scaling>1500</input_scaling>
          <zero_position_disarmed>0</zero_position_disarmed>
          <zero_position_armed>100</zero_position_armed>
          <joint_control_type>velocity</joint_control_type>
        </channel>
       <channel name="rotor5">
          <input_index>5</input_index>
          <input_offset>0</input_offset>
          <input_scaling>1500</input_scaling>
          <zero_position_disarmed>0</zero_position_disarmed>
          <zero_position_armed>100</zero_position_armed>
          <joint_control_type>velocity</joint_control_type>
        </channel>
      </control_channels>
    </plugin>
  </gazebo>


  <transmission name="manipulator_base_yaw_joint_tran">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="manipulator_base_yaw_joint">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="manipulator_base_yaw_joint_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="manipulator_arm1_joint_tran">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="manipulator_arm1_joint">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="manipulator_arm1_joint_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <transmission name="manipulator_arm2_joint_tran">
    <type>transmission_interface/SimpleTransmission</type>
    <joint name="manipulator_arm2_joint">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
    </joint>
    <actuator name="manipulator_arm2_joint_motor">
      <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
      <mechanicalReduction>1</mechanicalReduction>
    </actuator>
  </transmission>

  <!-- ros_control plugin -->
  <gazebo>
    <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
      <robotNamespace>/hexa_x_tilt</robotNamespace>
      <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
    </plugin>
  </gazebo>


</robot>
